{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "tflite"
  ],
  "ios": {
    "iosModuleName": "NitroTflite"
  },
  "android": {
    "androidNamespace": [
      "tflite"
    ],
    "androidCxxLibName": "NitroTflite"
  },
  "autolinking": {
    "TfliteModule": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridTfliteModule"
      }
    },
    "AssetLoader": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridAssetLoader"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridAssetLoader"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
